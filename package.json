{
  "name": "alexwebmaster",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/generate-data.ts",
    "dev": "npm run generate && next dev",
    "build": "rm -rf public/projects && cp -r projects public/projects && npm run generate && opennextjs-cloudflare build",
    "preview": "rm -rf public/projects && cp -r projects public/projects && npm run generate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint app/",
    "deploy": "rm -rf public/projects && cp -r projects public/projects && npm run generate && opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "nextBundleAnalysis": {
    "open": true
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource/inter": "^5.2.8",
    "@opennextjs/cloudflare": "^1.19.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
